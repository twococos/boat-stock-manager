# Copia aquest fitxer a .env.local i omple els valors del teu projecte Supabase.
# (Settings → API al panell de Supabase)
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Email fix de l'usuari compartit de la tripulació (la contrasenya és la del vaixell,
# que cada tripulant escriu al login). Veure auth/AuthProvider.tsx.
VITE_CREW_EMAIL=crew@boat-stock-manager.local
